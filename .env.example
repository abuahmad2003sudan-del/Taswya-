# --- Payment Configuration ---
# 'sandbox' or 'production'
PAYMENT_MODE=sandbox

# PayTabs Configuration
PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_REGION=ARE

# Payoneer Configuration
PAYONEER_CLIENT_ID=
PAYONEER_CLIENT_SECRET=

# MTGR Sudan Store Webhook Secret
MTGR_WEBHOOK_SECRET=

# --- Firebase Configuration ---
# These are usually handled by firebase-applet-config.json
# But can be set here for local development
GEMINI_API_KEY=

# --- Deployment Instructions ---
# 1. Set environment variables in Firebase Functions:
#    firebase functions:config:set mtgr.webhook_secret="YOUR_SECRET" payment.mode="production"
# 2. For React (Vite), prefix with VITE_ if needed for client-side access:
#    VITE_PAYMENT_MODE=sandbox
